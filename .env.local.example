# ============================================================
# Supabase
# ============================================================
# Supabase プロジェクト設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Google Gemini API
# ============================================================
# https://aistudio.google.com/app/apikey から取得
GEMINI_API_KEY=your-gemini-api-key

# ============================================================
# Stripe
# ============================================================
# https://dashboard.stripe.com/apikeys から取得
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Standard プラン（月額 1,480円）の Price ID
STRIPE_STANDARD_PRICE_ID=price_xxxxxxxxxxxx

# Pro プラン（月額 2,980円）の Price ID
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx

# --- テスト用 Price ID（必要時のみ設定） ---
STRIPE_STANDARD_TEST_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_PRO_TEST_PRICE_ID=price_xxxxxxxxxxxx

# true にすると checkout で test 用 Price ID を使う
STRIPE_USE_TEST_PRICE_IDS=false

# ============================================================
# App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
