# ============================================================
# TrainerDocs — 環境変数テンプレート
# このファイルをコピーして .env.local を作成し、各値を埋めてください。
# ============================================================

# ============================================================
# Supabase
# ============================================================
# Supabase プロジェクト設定 > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# Google Gemini API
# ============================================================
# https://aistudio.google.com/app/apikey から取得
GEMINI_API_KEY=

# ============================================================
# Stripe
# ============================================================
# https://dashboard.stripe.com/apikeys から取得
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...   # または pk_test_...（テスト時）
STRIPE_SECRET_KEY=sk_live_...                    # または sk_test_...（テスト時）
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price ID ──────────────────────────────────────────
# Stripe ダッシュボード > 商品 > 各プランの Price ID を設定する。
# ※ テスト環境では test モードの Price ID を使うこと。

# Standard プラン（月額 1,480円・税込）
# Stripe ダッシュボードで月額 1,480円の Price を作成して貼り付ける
STRIPE_STANDARD_PRICE_ID=

# Pro プラン（月額 2,980円・税込）
# Stripe ダッシュボードで月額 2,980円の Price を作成して貼り付ける
STRIPE_PRO_PRICE_ID=

# --- テスト用 Price ID（必要時のみ設定） ---
STRIPE_STANDARD_TEST_PRICE_ID=
STRIPE_PRO_TEST_PRICE_ID=

# true にすると checkout で test 用 Price ID を使う
STRIPE_USE_TEST_PRICE_IDS=false

# ↓ 廃止予定（後方互換フォールバック用）
#   STRIPE_STANDARD_PRICE_ID / STRIPE_PRO_PRICE_ID が両方設定されれば削除可
# NEXT_PUBLIC_STRIPE_PRICE_ID=

# ============================================================
# App
# ============================================================
# デプロイ先の URL（末尾スラッシュなし）
NEXT_PUBLIC_APP_URL=https://your-app.pages.dev
